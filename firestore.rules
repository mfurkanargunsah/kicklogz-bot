rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Sadece okuma izni — yazma sadece backend (service account) yapabilir
    match /channels/{channel} {
      allow read: if true;
      allow write: if false;
    }
    match /channels/{channel}/chatters/{user} {
      allow read: if true;
      allow write: if false;
    }
    match /messages/{msg} {
      allow read: if true;
      allow write: if false;
    }
  }
}
